MACRO CSeries_D_2_1
  UNITS
    DATABASE MICRONS UNITS 1000;
  END UNITS
  ORIGIN 0 0 ;
  FOREIGN CSeries_D_2_1 0 0 ;
  SIZE 8150 BY 9590 ;
  PIN MINUS
    DIRECTION INOUT ;
